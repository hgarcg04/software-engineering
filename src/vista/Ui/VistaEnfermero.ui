  <property name="styleSheet">
   <string notr="true">
    QMainWindow { background-color: #f0f4f8; }

    #topBar {
        background-color: #ffffff;
        border-bottom: 1px solid #dde3ea;
        min-height: 60px;
    }
    #lbl_app_name { font-family: 'Segoe UI Black'; font-size: 20px; color: #00b894; }
    #lbl_user_name { font-family: 'Segoe UI'; font-size: 14px; color: #2d3436; }
    #lbl_datetime  { font-family: 'Segoe UI'; font-size: 13px; color: #636e72; }
    #btn_logout {
        background-color: #e17055;
        color: white;
        border-radius: 8px;
        padding: 6px 16px;
        font-family: 'Segoe UI Semibold';
        font-size: 13px;
    }
    #btn_logout:hover { background-color: #c0392b; }

    #sideBar {
        background-color: #2d3436;
        min-width: 200px;
        max-width: 200px;
    }
    #lbl_menu_title {
        color: #b2bec3;
        font-family: 'Segoe UI';
        font-size: 11px;
        padding-left: 20px;
        padding-top: 10px;
    }
    QPushButton[class=&quot;navBtn&quot;] {
        background-color: transparent;
        color: #dfe6e9;
        border: none;
        text-align: left;
        padding: 12px 20px;
        font-family: 'Segoe UI';
        font-size: 14px;
    }
    QPushButton[class=&quot;navBtn&quot;]:hover { background-color: #3d5166; }
    QPushButton[class=&quot;navBtn&quot;]:checked { background-color: #00b894; color: white; }

    #centralPanel { background-color: #f0f4f8; }
    #lbl_section_title {
        font-family: 'Segoe UI Black';
        font-size: 22px;
        color: #2d3436;
    }
    #lbl_section_sub {
        font-family: 'Segoe UI';
        font-size: 13px;
        color: #636e72;
    }

    QTableWidget {
        background-color: #ffffff;
        border: 1px solid #dde3ea;
        border-radius: 10px;
        gridline-color: #f0f4f8;
        font-size: 13px;
    }
    QTableWidget::item { padding: 8px; }
    QTableWidget::item:selected { background-color: #d8f3ed; color: #2d3436; }
    QHeaderView::section {
        background-color: #f8fafc;
        color: #636e72;
        font-family: 'Segoe UI Semibold';
        font-size: 12px;
        padding: 8px;
        border: none;
        border-bottom: 1px solid #dde3ea;
    }

    #frame_paciente_seleccionado {
        background-color: #d8f3ed;
        border: 1.5px solid #00b894;
        border-radius: 10px;
        padding: 4px 12px;
    }
    #frame_pac_constantes {
        background-color: #d8f3ed;
        border: 1.5px solid #00b894;
        border-radius: 10px;
        padding: 4px 12px;
    }
    #frame_pac_medicacion {
        background-color: #d8f3ed;
        border: 1.5px solid #00b894;
        border-radius: 10px;
        padding: 4px 12px;
    }
    #lbl_paciente_sel_texto {
        font-family: 'Segoe UI';
        font-size: 13px;
        color: #636e72;
    }
    #lbl_paciente_sel_nombre, #lbl_paciente_sel_nombre_2, #lbl_paciente_sel_nombre3 {
        font-family: 'Segoe UI Semibold';
        font-size: 14px;
        color: #00a381;
    }
    #btn_deseleccionar {
        background-color: transparent;
        color: #e17055;
        border: 1px solid #e17055;
        border-radius: 6px;
        padding: 3px 10px;
        font-size: 12px;
    }
    #btn_deseleccionar:hover { background-color: #ffecea; }

    #btn_nuevo_registro, #btn_suministrar {
        background-color: #00b894;
        color: white;
        border-radius: 8px;
        padding: 8px 18px;
        font-family: 'Segoe UI Semibold';
        font-size: 13px;
    }
    #btn_nuevo_registro:hover, #btn_suministrar:hover { background-color: #00a381; }
    #btn_nuevo_registro:disabled, #btn_suministrar:disabled {
        background-color: #b2d8d0;
        color: #ffffff;
    }

    #btn_ver_registros {
        background-color: #6a9edb;
        color: white;
        border-radius: 8px;
        padding: 8px 18px;
        font-family: 'Segoe UI Semibold';
        font-size: 13px;
    }
    #btn_ver_registros:hover { background-color: #4a7ec0; }
    #btn_ver_registros:disabled {
        background-color: #cfe0f5;
        color: #a0b8d0;
    }

    #btn_anadir_registro {
        background-color: #00b894;
        color: white;
        border-radius: 8px;
        padding: 8px 18px;
        font-family: 'Segoe UI Semibold';
        font-size: 13px;
    }
    #btn_anadir_registro:hover { background-color: #00a381; }

    #btn_guardar_registro {
        background-color: #2d3436;
        color: white;
        border-radius: 8px;
        padding: 8px 18px;
        font-family: 'Segoe UI Semibold';
        font-size: 13px;
    }
    #btn_guardar_registro:hover { background-color: #1a1f20; }
    #btn_guardar_registro:disabled {
        background-color: #b2bec3;
        color: #ffffff;
    }

    #btn_ver_historico {
        background-color: #6a9edb;
        color: white;
        border-radius: 8px;
        padding: 8px 18px;
        font-family: 'Segoe UI Semibold';
        font-size: 13px;
    }
    #btn_ver_historico:hover { background-color: #4a7ec0; }

    #btn_borrar_seleccionado {
        background-color: transparent;
        color: #e17055;
        border: 1px solid #e17055;
        border-radius: 6px;
        padding: 6px 12px;
        font-size: 12px;
    }
    #btn_borrar_seleccionado:hover { background-color: #ffecea; }

    #btn_borrar_todo {
        background-color: transparent;
        color: #636e72;
        border: 1px solid #b2bec3;
        border-radius: 6px;
        padding: 6px 12px;
        font-size: 12px;
    }
    #btn_borrar_todo:hover { background-color: #dfe6e9; }

    #lbl_pendientes_titulo {
        font-family: 'Segoe UI Semibold';
        font-size: 13px;
        color: #2d3436;
    }

    #search_bar {
        border: 1px solid #dde3ea;
        border-radius: 8px;
        padding: 8px 12px;
        background-color: #ffffff;
        font-size: 13px;
        color: #2d3436;
        min-width: 280px;
    }
    #search_bar:focus { border: 1px solid #00b894; }

    #frame_detalle_episodio {
        background-color: #ffffff;
        border: 1px solid #dde3ea;
        border-radius: 10px;
    }
    #lbl_detalle_titulo {
        font-family: 'Segoe UI Black';
        font-size: 18px;
        color: #2d3436;
    }
    #lbl_detalle_sub {
        font-family: 'Segoe UI';
        font-size: 12px;
        color: #636e72;
    }
    #btn_cerrar_detalle, #btn_cerrar_detalles_ingreso {
        background-color: #dfe6e9;
        color: #2d3436;
        border: none;
        border-radius: 6px;
        padding: 5px 14px;
        font-size: 13px;
    }
    #btn_cerrar_detalle:hover, #btn_cerrar_detalles_ingreso:hover { background-color: #b2bec3; }
    QTextEdit#txt_detalle_episodio {
        background-color: #f8fafc;
        border: 1px solid #dde3ea;
        border-radius: 8px;
        font-family: 'Segoe UI';
        font-size: 13px;
        color: #2d3436;
        padding: 10px;
    }

    /* === Estilos específicos de la página de medicación === */
    #frame_tratamiento_seleccionado {
        background-color: #eaf4fb;
        border: 1.5px solid #6a9edb;
        border-radius: 10px;
        padding: 4px 12px;
    }
    #lbl_tratamiento_sel_texto {
        font-family: 'Segoe UI';
        font-size: 13px;
        color: #636e72;
    }
    #lbl_tratamiento_sel_nombre {
        font-family: 'Segoe UI Semibold';
        font-size: 14px;
        color: #4a7ec0;
    }
    #lbl_dosis_info {
        font-family: 'Segoe UI Semibold';
        font-size: 13px;
        color: #2d3436;
        background-color: #f8fafc;
        border: 1px solid #dde3ea;
        border-radius: 8px;
        padding: 8px 12px;
    }
    #btn_confirmar_toma {
        background-color: #00b894;
        color: white;
        border-radius: 8px;
        padding: 10px 24px;
        font-family: 'Segoe UI Semibold';
        font-size: 14px;
    }
    #btn_confirmar_toma:hover { background-color: #00a381; }
    #btn_confirmar_toma:disabled {
        background-color: #b2d8d0;
        color: #ffffff;
    }
    #lbl_tomas_titulo {
        font-family: 'Segoe UI Semibold';
        font-size: 13px;
        color: #2d3436;
    }
    #lbl_med_instrucciones {
        font-family: 'Segoe UI';
        font-size: 12px;
        color: #636e72;
        padding: 4px 0px;
    }
