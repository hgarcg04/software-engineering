<?xml version="1.0" encoding="UTF-8"?>
<ui version="4.0">
 <class>VistaEnfermero</class>
 <widget class="QMainWindow" name="VistaEnfermero">
  <property name="geometry">
   <rect>
    <x>0</x>
    <y>0</y>
    <width>1200</width>
    <height>800</height>
   </rect>
  </property>
  <property name="windowTitle">
   <string>KURA - Panel Enfermero</string>
  </property>
  <property name="styleSheet">
   <string notr="true">
    QMainWindow { background-color: #f0f4f8; }

    /* Barra superior */
    #topBar {
        background-color: #ffffff;
        border-bottom: 1px solid #dde3ea;
        min-height: 60px;
    }
    #lbl_app_name { font-family: 'Segoe UI Black'; font-size: 20px; color: #00b894; }
    #lbl_user_name { font-family: 'Segoe UI'; font-size: 14px; color: #2d3436; }
    #lbl_datetime  { font-family: 'Segoe UI'; font-size: 13px; color: #636e72; }
    #btn_logout {
        background-color: #e17055;
        color: white;
        border-radius: 8px;
        padding: 6px 16px;
        font-family: 'Segoe UI Semibold';
        font-size: 13px;
    }
    #btn_logout:hover { background-color: #c0392b; }

    /* Barra lateral */
    #sideBar {
        background-color: #2d3436;
        min-width: 200px;
        max-width: 200px;
    }
    #lbl_menu_title {
        color: #b2bec3;
        font-family: 'Segoe UI';
        font-size: 11px;
        padding-left: 20px;
        padding-top: 10px;
    }
    QPushButton[class=&quot;navBtn&quot;] {
        background-color: transparent;
        color: #dfe6e9;
        border: none;
        text-align: left;
        padding: 12px 20px;
        font-family: 'Segoe UI';
        font-size: 14px;
    }
    QPushButton[class=&quot;navBtn&quot;]:hover { background-color: #3d5166; }
    QPushButton[class=&quot;navBtn&quot;]:checked { background-color: #00b894; color: white; }

    /* Panel central */
    #centralPanel { background-color: #f0f4f8; }
    #lbl_section_title {
        font-family: 'Segoe UI Black';
        font-size: 22px;
        color: #2d3436;
    }
    #lbl_section_sub {
        font-family: 'Segoe UI';
        font-size: 13px;
        color: #636e72;
    }

    /* Tabla pacientes */
    QTableWidget {
        background-color: #ffffff;
        border: 1px solid #dde3ea;
        border-radius: 10px;
        gridline-color: #f0f4f8;
        font-size: 13px;
    }
    QTableWidget::item { padding: 8px; }
    QTableWidget::item:selected { background-color: #d8f3ed; color: #2d3436; }
    QHeaderView::section {
        background-color: #f8fafc;
        color: #636e72;
        font-family: 'Segoe UI Semibold';
        font-size: 12px;
        padding: 8px;
        border: none;
        border-bottom: 1px solid #dde3ea;
    }

    /* Banner de paciente seleccionado */
    #frame_paciente_seleccionado {
        background-color: #d8f3ed;
        border: 1.5px solid #00b894;
        border-radius: 10px;
        padding: 4px 12px;
    }
    #lbl_paciente_sel_texto {
        font-family: 'Segoe UI';
        font-size: 13px;
        color: #636e72;
    }
    #lbl_paciente_sel_nombre {
        font-family: 'Segoe UI Semibold';
        font-size: 14px;
        color: #00a381;
    }
    #btn_deseleccionar {
        background-color: transparent;
        color: #e17055;
        border: 1px solid #e17055;
        border-radius: 6px;
        padding: 3px 10px;
        font-size: 12px;
    }
    #btn_deseleccionar:hover { background-color: #ffecea; }

    /* Botones de acción */
    #btn_nuevo_registro, #btn_suministrar {
        background-color: #00b894;
        color: white;
        border-radius: 8px;
        padding: 8px 18px;
        font-family: 'Segoe UI Semibold';
        font-size: 13px;
    }
    #btn_nuevo_registro:hover, #btn_suministrar:hover { background-color: #00a381; }
    #btn_nuevo_registro:disabled, #btn_suministrar:disabled {
        background-color: #b2d8d0;
        color: #ffffff;
    }
    #btn_ver_registros {
        background-color: #6a9edb;
        color: white;
        border-radius: 8px;
        padding: 8px 18px;
        font-family: 'Segoe UI Semibold';
        font-size: 13px;
    }
    #btn_ver_registros:hover { background-color: #5a8dc7; }

    /* Buscador */
    #search_bar {
        border: 1px solid #dde3ea;
        border-radius: 8px;
        padding: 8px 12px;
        background-color: #ffffff;
        font-size: 13px;
        color: #2d3436;
        min-width: 280px;
    }
    #search_bar:focus { border: 1px solid #00b894; }

    /* Panel detalle episodio */
    #frame_detalle_episodio {
        background-color: #ffffff;
        border: 1px solid #dde3ea;
        border-radius: 10px;
    }
    #lbl_detalle_titulo {
        font-family: 'Segoe UI Black';
        font-size: 18px;
        color: #2d3436;
    }
    #lbl_detalle_sub {
        font-family: 'Segoe UI';
        font-size: 12px;
        color: #636e72;
    }
    #btn_cerrar_detalle {
        background-color: #dfe6e9;
        color: #2d3436;
        border: none;
        border-radius: 6px;
        padding: 5px 14px;
        font-size: 13px;
    }
    #btn_cerrar_detalle:hover { background-color: #b2bec3; }
    QTextEdit#txt_detalle_episodio {
        background-color: #f8fafc;
        border: 1px solid #dde3ea;
        border-radius: 8px;
        font-family: 'Segoe UI';
        font-size: 13px;
        color: #2d3436;
        padding: 10px;
    }
   </string>
