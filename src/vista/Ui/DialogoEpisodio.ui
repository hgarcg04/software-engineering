<ui version="4.0">
 <class>DialogoEpisodio</class>
 <widget class="QDialog" name="DialogoEpisodio">
  <property name="geometry">
   <rect><x>0</x><y>0</y><width>700</width><height>500</height></rect>
  </property>
  <property name="windowTitle"><string>KURA - Seleccionar episodio clínico</string></property>
  <property name="styleSheet">
   <string notr="true">
    QDialog { background-color: #f0f4f8; }
    #lbl_titulo { font-family: 'Segoe UI Black'; font-size: 20px; color: #2d3436; }
    #lbl_subtitulo { font-family: 'Segoe UI'; font-size: 13px; color: #636e72; }
    #frame_pac { background-color: #d8f3ed; border: 1.5px solid #00b894; border-radius: 10px; padding: 4px 12px; }
    #lbl_pac_texto { font-family: 'Segoe UI'; font-size: 13px; color: #636e72; }
    #lbl_pac_nombre { font-family: 'Segoe UI Semibold'; font-size: 14px; color: #00a381; }
    QTableWidget { background-color: #ffffff; border: 1px solid #dde3ea; border-radius: 10px; gridline-color: #f0f4f8; font-size: 13px; }
    QTableWidget::item { padding: 8px; }
    QTableWidget::item:selected { background-color: #00a381; color: white; }
    QHeaderView::section { background-color: #f8fafc; color: #636e72; font-family: 'Segoe UI Semibold'; font-size: 12px; padding: 8px; border: none; border-bottom: 1px solid #dde3ea; }
    #btn_usar_episodio { background-color: #6a9edb; color: white; border-radius: 8px; padding: 10px 24px; font-family: 'Segoe UI Semibold'; font-size: 14px; border: none; }
    #btn_usar_episodio:hover { background-color: #4a7ec0; }
    #btn_usar_episodio:disabled { background-color: #cfe0f5; color: #a0b8d0; }
    #btn_nuevo_episodio { background-color: #00b894; color: white; border-radius: 8px; padding: 10px 24px; font-family: 'Segoe UI Semibold'; font-size: 14px; border: none; }
    #btn_nuevo_episodio:hover { background-color: #00a381; }
    #btn_cancelar { background-color: #dfe6e9; color: #2d3436; border-radius: 8px; padding: 10px 24px; font-family: 'Segoe UI Semibold'; font-size: 14px; border: none; }
    #btn_cancelar:hover { background-color: #b2bec3; }
    #lbl_col_titulo { font-family: 'Segoe UI Semibold'; font-size: 15px; color: #2d3436; }
   </string>
  </property>
  <layout class="QVBoxLayout" name="mainLayout">
   <property name="spacing"><number>12</number></property>
