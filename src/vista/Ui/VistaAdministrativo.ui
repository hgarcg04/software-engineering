        <!-- ══════════════ PAGE 1: REGISTRAR PACIENTE ══════════════ -->
        <widget class="QWidget" name="page_pacientes">
         <layout class="QVBoxLayout" name="pacientesLayout">
          <property name="leftMargin"><number>30</number></property>
          <property name="topMargin"><number>20</number></property>
          <property name="rightMargin"><number>30</number></property>
          <property name="bottomMargin"><number>20</number></property>
          <property name="spacing"><number>8</number></property>
          <item>
           <widget class="QLabel" name="lbl_section_title">
               <property name="class" stdset="0"><string>sectionTitle</string></property>
            <property name="text"><string>Registrar Paciente</string></property>
           </widget>
          </item>
          <item>
           <widget class="QLabel" name="lbl_section_sub">
               <property name="class" stdset="0"><string>sectionSub</string></property>
            <property name="text"><string>Introduce los datos del nuevo paciente. El DNI no debe existir previamente en el sistema.</string></property>
           </widget>
          </item>
          <item>
           <widget class="QGroupBox" name="groupBox_datos_paciente">
            <property name="title"><string>Datos personales</string></property>
            <layout class="QFormLayout" name="formPaciente">
             <property name="leftMargin"><number>16</number></property>
             <property name="topMargin"><number>12</number></property>
             <property name="rightMargin"><number>16</number></property>
             <property name="bottomMargin"><number>12</number></property>
             <property name="horizontalSpacing"><number>20</number></property>
             <property name="verticalSpacing"><number>14</number></property>
             <item row="0" column="0">
              <widget class="QLabel" name="lbl_f_nombre">
               <property name="text"><string>Nombre completo *</string></property>
               <property name="class" stdset="0"><string>formLabel</string></property>
              </widget>
             </item>
             <item row="0" column="1">
              <widget class="QLineEdit" name="input_nombre_paciente">
               <property name="placeholderText"><string>Ej: Ana García López</string></property>
              </widget>
             </item>
             <item row="1" column="0">
              <widget class="QLabel" name="lbl_f_dni">
               <property name="text"><string>DNI *</string></property>
               <property name="class" stdset="0"><string>formLabel</string></property>
              </widget>
             </item>
             <item row="1" column="1">
              <widget class="QLineEdit" name="input_dni_paciente">
               <property name="placeholderText"><string>Ej: 12345678A</string></property>
               <property name="maxLength"><number>9</number></property>
              </widget>
             </item>
             <item row="2" column="0">
              <widget class="QLabel" name="lbl_f_fnac">
               <property name="text"><string>Fecha de nacimiento *</string></property>
               <property name="class" stdset="0"><string>formLabel</string></property>
              </widget>
             </item>
             <item row="2" column="1">
              <widget class="QDateEdit" name="input_fnac_paciente">
               <property name="calendarPopup"><bool>true</bool></property>
               <property name="displayFormat"><string>dd/MM/yyyy</string></property>
              </widget>
             </item>
             <item row="3" column="0">
              <widget class="QLabel" name="lbl_f_telefono">
               <property name="text"><string>Teléfono</string></property>
               <property name="class" stdset="0"><string>formLabel</string></property>
              </widget>
             </item>
             <item row="3" column="1">
              <widget class="QLineEdit" name="input_telefono_paciente">
               <property name="placeholderText"><string>Ej: 612 345 678</string></property>
              </widget>
             </item>
             <item row="4" column="0">
              <widget class="QLabel" name="lbl_f_email">
