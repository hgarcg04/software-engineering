<?xml version="1.0" encoding="UTF-8"?>
<ui version="4.0">
 <class>VistaAdministrativo</class>
 <widget class="QMainWindow" name="VistaAdministrativo">
  <property name="geometry">
   <rect>
    <x>0</x>
    <y>0</y>
    <width>1200</width>
    <height>800</height>
   </rect>
  </property>
  <property name="windowTitle">
   <string>KURA - Panel Administrativo</string>
  </property>
  <property name="styleSheet">
   <string notr="true">
    QMainWindow { background-color: #f0f4f8; }

    #topBar {
        background-color: #ffffff;
        border-bottom: 1px solid #dde3ea;
        min-height: 60px;
    }
    #lbl_app_name { font-family: 'Segoe UI Black'; font-size: 20px; color: #00b894; }
    #lbl_user_name { font-family: 'Segoe UI'; font-size: 14px; color: #2d3436; }
    #lbl_datetime  { font-family: 'Segoe UI'; font-size: 13px; color: #636e72; }
    #btn_logout {
        background-color: #e17055;
        color: white;
        border-radius: 8px;
        padding: 6px 16px;
        font-family: 'Segoe UI Semibold';
        font-size: 13px;
    }
    #btn_logout:hover { background-color: #c0392b; }

    #sideBar {
        background-color: #2d3436;
        min-width: 200px;
        max-width: 200px;
    }
    #lbl_menu_title {
        color: #b2bec3;
        font-family: 'Segoe UI';
        font-size: 11px;
        padding-left: 20px;
        padding-top: 10px;
    }
    QPushButton[class=&quot;navBtn&quot;] {
        background-color: transparent;
        color: #dfe6e9;
        border: none;
        text-align: left;
        padding: 12px 20px;
        font-family: 'Segoe UI';
        font-size: 14px;
    }
    QPushButton[class=&quot;navBtn&quot;]:hover { background-color: #3d5166; }
    QPushButton[class=&quot;navBtn&quot;]:checked { background-color: #00b894; color: white; }

    #centralPanel { background-color: #f0f4f8; }
    QLabel[class=&quot;sectionTitle&quot;] {
        font-family: 'Segoe UI Black';
        font-size: 22px;
        color: #2d3436;
    }
    QLabel[class=&quot;sectionSub&quot;] {
        font-family: 'Segoe UI';
        font-size: 13px;
        color: #636e72;
    }

    QTableWidget {
        background-color: #ffffff;
        border: 1px solid #dde3ea;
        border-radius: 10px;
        gridline-color: #f0f4f8;
        font-size: 13px;
    }
    QTableWidget::item { padding: 8px; }
    QTableWidget::item:selected { background-color: #d8f3ed; color: #2d3436; }
    QHeaderView::section {
        background-color: #f8fafc;
        color: #636e72;
        font-family: 'Segoe UI Semibold';
        font-size: 12px;
        padding: 8px;
        border: none;
        border-bottom: 1px solid #dde3ea;
    }

    #search_bar {
        border: 1px solid #dde3ea;
        border-radius: 8px;
        padding: 8px 12px;
        background-color: #ffffff;
        font-size: 13px;
        color: #2d3436;
        min-width: 280px;
    }
    #search_bar:focus { border: 1px solid #00b894; }

    QLineEdit, QDateEdit, QComboBox, QSpinBox, QTimeEdit {
        border: 1px solid #dde3ea;
        border-radius: 8px;
        padding: 8px 12px;
        background-color: #ffffff;
        font-size: 13px;
        color: #2d3436;
    }
    QLineEdit:focus, QDateEdit:focus, QComboBox:focus, QSpinBox:focus, QTimeEdit:focus {
        border: 1px solid #00b894;
    }
    QTextEdit {
        background-color: #f8fafc;
        border: 1px solid #dde3ea;
        border-radius: 8px;
        font-family: 'Segoe UI';
        font-size: 13px;
        color: #2d3436;
        padding: 10px;
    }
    QLabel[class=&quot;formLabel&quot;] {
        font-family: 'Segoe UI Semibold';
        font-size: 13px;
        color: #2d3436;
        min-height: 32px;
        padding-top: 2px;
    }

    /* === Frames de paciente/entidad seleccionada === */
    #frame_paciente_seleccionado, #frame_medico_seleccionado {
        background-color: #d8f3ed;
        border: 1.5px solid #00b894;
        border-radius: 10px;
        padding: 4px 12px;
    }
    #lbl_paciente_sel_texto, #lbl_medico_sel_texto {
        font-family: 'Segoe UI';
        font-size: 13px;
        color: #636e72;
    }
    #lbl_paciente_sel_nombre, #lbl_medico_sel_nombre {
        font-family: 'Segoe UI Semibold';
        font-size: 14px;
        color: #00a381;
    }
    #btn_deseleccionar {
        background-color: transparent;
        color: #e17055;
        border: 1px solid #e17055;
        border-radius: 6px;
        padding: 3px 10px;
        font-size: 12px;
    }
    #btn_deseleccionar:hover { background-color: #ffecea; }

    /* === Botones primarios verdes === */
    #btn_registrar_paciente, #btn_asignar_cita, #btn_generar_credenciales,
    #btn_confirmar_pedido, #btn_crear_backup, #btn_bloquear_agenda,
    #btn_guardar_paciente, #btn_guardar_credencial {
        background-color: #00b894;
        color: white;
        border-radius: 8px;
        padding: 8px 18px;
        font-family: 'Segoe UI Semibold';
        font-size: 13px;
    }
    #btn_registrar_paciente:hover, #btn_asignar_cita:hover, #btn_generar_credenciales:hover,
    #btn_confirmar_pedido:hover, #btn_crear_backup:hover, #btn_bloquear_agenda:hover,
    #btn_guardar_paciente:hover, #btn_guardar_credencial:hover { background-color: #00a381; }
    #btn_registrar_paciente:disabled, #btn_asignar_cita:disabled,
    #btn_confirmar_pedido:disabled, #btn_bloquear_agenda:disabled {
        background-color: #b2d8d0;
        color: #ffffff;
    }

    /* === Botones secundarios azules === */
    #btn_buscar_paciente, #btn_buscar_medico, #btn_consultar_disponibilidad,
    #btn_ver_detalle_paciente {
        background-color: #6a9edb;
        color: white;
        border-radius: 8px;
        padding: 8px 18px;
        font-family: 'Segoe UI Semibold';
        font-size: 13px;
    }
    #btn_buscar_paciente:hover, #btn_buscar_medico:hover,
    #btn_consultar_disponibilidad:hover, #btn_ver_detalle_paciente:hover { background-color: #4a7ec0; }
    #btn_buscar_paciente:disabled, #btn_consultar_disponibilidad:disabled {
        background-color: #cfe0f5;
        color: #a0b8d0;
    }

    /* === Botones de acción neutral === */
    #btn_limpiar_formulario, #btn_cancelar, #btn_nuevo_paciente {
        background-color: #dfe6e9;
        color: #2d3436;
        border: none;
        border-radius: 8px;
        padding: 8px 18px;
        font-family: 'Segoe UI Semibold';
        font-size: 13px;
    }
    #btn_limpiar_formulario:hover, #btn_cancelar:hover,
    #btn_nuevo_paciente:hover { background-color: #b2bec3; }

    /* === Frame de disponibilidad / resultado === */
    #frame_disponibilidad {
        background-color: #ffffff;
        border: 1px solid #dde3ea;
        border-radius: 10px;
    }
    #lbl_disponibilidad_titulo {
        font-family: 'Segoe UI Black';
        font-size: 15px;
        color: #2d3436;
    }

    /* === Frame de detalle de cita / backup === */
    #frame_info_backup {
        background-color: #eaf4fb;
        border: 1.5px solid #6a9edb;
        border-radius: 10px;
        padding: 12px 16px;
    }
    #lbl_backup_estado {
        font-family: 'Segoe UI Semibold';
        font-size: 14px;
        color: #4a7ec0;
    }
    #lbl_backup_sub {
        font-family: 'Segoe UI';
        font-size: 12px;
        color: #636e72;
    }

    /* === Alerta / advertencia === */
    #frame_alerta {
        background-color: #fff3cd;
        border: 1.5px solid #f39c12;
        border-radius: 10px;
        padding: 8px 14px;
    }
    #lbl_alerta_texto {
        font-family: 'Segoe UI';
        font-size: 13px;
        color: #856404;
    }

    /* === Calendario de disponibilidad === */
    QCalendarWidget {
        background-color: #ffffff;
        border: 1px solid #dde3ea;
        border-radius: 10px;
    }
    QCalendarWidget QTableView {
        selection-background-color: #00b894;
        selection-color: white;
    }

    /* === GroupBox === */
    QGroupBox {
        font-family: 'Segoe UI Semibold';
        font-size: 13px;
        color: #2d3436;
        border: 1px solid #dde3ea;
        border-radius: 10px;
        margin-top: 14px;
        padding-top: 10px;
        background-color: #ffffff;
    }
    QGroupBox::title {
        subcontrol-origin: margin;
        subcontrol-position: top left;
        padding: 0 8px;
        color: #636e72;
    }

    /* === Barra de progreso backup === */
    QProgressBar {
        border: 1px solid #dde3ea;
        border-radius: 8px;
        background-color: #f0f4f8;
        text-align: center;
        font-size: 12px;
        color: #2d3436;
        min-height: 20px;
    }
    QProgressBar::chunk {
        background-color: #00b894;
        border-radius: 8px;
    }

    /* === Spinbox de cantidad medicamentos === */
    #spin_cantidad {
        min-width: 80px;
        max-width: 100px;
    }

    /* === Badge de stock bajo === */
    #lbl_stock_bajo {
        background-color: #e17055;
        color: white;
        border-radius: 6px;
        padding: 2px 8px;
        font-family: 'Segoe UI Semibold';
        font-size: 11px;
    }
   </string>
