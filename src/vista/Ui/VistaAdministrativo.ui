             <property name="topMargin"><number>20</number></property>
             <property name="rightMargin"><number>16</number></property>
             <property name="bottomMargin"><number>16</number></property>
             <item>
              <layout class="QHBoxLayout">
               <item>
                <widget class="QLabel" name="lbl_cantidad_label">
                 <property name="text"><string>Cantidad a pedir:</string></property>
                 <property name="class" stdset="0"><string>formLabel</string></property>
                </widget>
               </item>
               <item>
                <widget class="QSpinBox" name="spin_cantidad">
                 <property name="minimum"><number>1</number></property>
                 <property name="maximum"><number>9999</number></property>
                 <property name="value"><number>1</number></property>
                </widget>
               </item>
               <item>
                <widget class="QPushButton" name="btn_anadir_al_pedido">
                 <property name="text"><string>+ Añadir al pedido</string></property>
                </widget>
               </item>
              </layout>
             </item>
             <item>
              <widget class="QLabel" name="lbl_pendientes_titulo">
               <property name="text"><string>Líneas del pedido:</string></property>
              </widget>
             </item>
             <item>
              <widget class="QTableWidget" name="tabla_pedido">
               <property name="editTriggers">
                <set>QAbstractItemView::NoEditTriggers</set>
               </property>
               <property name="selectionBehavior">
                <enum>QAbstractItemView::SelectRows</enum>
               </property>
               <property name="columnCount"><number>3</number></property>
               <attribute name="horizontalHeaderStretchLastSection"><bool>true</bool></attribute>
               <column><property name="text"><string>Medicamento</string></property></column>
               <column><property name="text"><string>Cantidad</string></property></column>
               <column><property name="text"><string>Unidad</string></property></column>
              </widget>
             </item>
             <item>
              <layout class="QHBoxLayout">
               <item>
                <widget class="QPushButton" name="btn_borrar_seleccionado">
                 <property name="text"><string>✕ Quitar seleccionado</string></property>
                </widget>
               </item>
               <item>
                <widget class="QPushButton" name="btn_borrar_todo">
                 <property name="text"><string>Vaciar pedido</string></property>
                </widget>
               </item>
              </layout>
             </item>
             <item>
              <widget class="QPushButton" name="btn_confirmar_pedido">
               <property name="enabled"><bool>false</bool></property>
               <property name="text"><string>Confirmar pedido</string></property>
              </widget>
             </item>
             <item>
              <spacer>
               <property name="orientation"><enum>Qt::Vertical</enum></property>
               <property name="sizeHint" stdset="0">
                <size><width>0</width><height>0</height></size>
               </property>
              </spacer>
             </item>
            </layout>
           </widget>
          </item>
         </layout>
        </widget>

        <!-- ══════════════ PAGE 6: COPIA DE SEGURIDAD ══════════════ -->
        <widget class="QWidget" name="page_backup">
         <layout class="QVBoxLayout" name="backupLayout">
          <property name="leftMargin"><number>30</number></property>
          <property name="topMargin"><number>30</number></property>
          <property name="rightMargin"><number>30</number></property>
          <property name="bottomMargin"><number>30</number></property>
          <item>
           <widget class="QLabel" name="lbl_section_title">
               <property name="class" stdset="0"><string>sectionTitle</string></property>
            <property name="text"><string>Copia de Seguridad</string></property>
           </widget>
          </item>
          <item>
           <widget class="QLabel" name="lbl_section_sub">
               <property name="class" stdset="0"><string>sectionSub</string></property>
            <property name="text"><string>Genera una copia de seguridad completa de la base de datos y archivos del sistema.</string></property>
           </widget>
          </item>

          <!-- Info del último backup -->
          <item>
           <widget class="QFrame" name="frame_info_backup">
            <layout class="QVBoxLayout" name="backupInfoLayout">
             <property name="leftMargin"><number>16</number></property>
             <property name="topMargin"><number>12</number></property>
             <property name="rightMargin"><number>16</number></property>
             <property name="bottomMargin"><number>12</number></property>
             <item>
              <widget class="QLabel" name="lbl_backup_estado">
               <property name="text"><string>Última copia de seguridad</string></property>
              </widget>
             </item>
             <item>
              <widget class="QLabel" name="lbl_backup_sub">
               <property name="text"><string>Fecha: —   |   Hora: —   |   Realizada por: —   |   Tamaño: —</string></property>
              </widget>
             </item>
            </layout>
           </widget>
          </item>

          <!-- Configuración del backup -->
          <item>
           <widget class="QGroupBox" name="groupBox_config_backup">
            <property name="title"><string>Configuración</string></property>
            <layout class="QFormLayout" name="formBackup">
             <property name="leftMargin"><number>20</number></property>
             <property name="topMargin"><number>20</number></property>
             <property name="rightMargin"><number>20</number></property>
             <property name="bottomMargin"><number>20</number></property>
             <property name="verticalSpacing"><number>14</number></property>
             <property name="horizontalSpacing"><number>20</number></property>
             <item row="0" column="0">
              <widget class="QLabel" name="lbl_bk_destino">
               <property name="text"><string>Directorio de destino</string></property>
               <property name="class" stdset="0"><string>formLabel</string></property>
              </widget>
             </item>
             <item row="0" column="1">
              <layout class="QHBoxLayout">
               <item>
                <widget class="QLineEdit" name="input_ruta_backup">
                 <property name="placeholderText"><string>/ruta/al/directorio/de/backup</string></property>
                 <property name="readOnly"><bool>true</bool></property>
                </widget>
               </item>
               <item>
                <widget class="QPushButton" name="btn_seleccionar_ruta">
                 <property name="text"><string>Examinar...</string></property>
                </widget>
               </item>
              </layout>
             </item>
             <item row="1" column="0">
              <widget class="QLabel" name="lbl_bk_tipo">
               <property name="text"><string>Tipo de copia</string></property>
               <property name="class" stdset="0"><string>formLabel</string></property>
              </widget>
             </item>
             <item row="1" column="1">
              <widget class="QComboBox" name="combo_tipo_backup">
               <item><property name="text"><string>Completa (base de datos + archivos)</string></property></item>
               <item><property name="text"><string>Solo base de datos</string></property></item>
               <item><property name="text"><string>Solo archivos</string></property></item>
              </widget>
             </item>
            </layout>
           </widget>
          </item>

          <!-- Barra de progreso (oculta inicialmente) -->
          <item>
           <widget class="QProgressBar" name="progress_backup">
            <property name="value"><number>0</number></property>
            <property name="visible"><bool>false</bool></property>
            <property name="textVisible"><bool>true</bool></property>
           </widget>
          </item>

          <!-- Historial de backups -->
          <item>
           <widget class="QGroupBox" name="groupBox_historial_backup">
            <property name="title"><string>Historial de copias</string></property>
            <layout class="QVBoxLayout" name="historialBackupLayout">
             <property name="leftMargin"><number>16</number></property>
             <property name="topMargin"><number>16</number></property>
             <property name="rightMargin"><number>16</number></property>
             <property name="bottomMargin"><number>16</number></property>
             <item>
              <widget class="QTableWidget" name="tabla_historial_backup">
               <property name="editTriggers">
                <set>QAbstractItemView::NoEditTriggers</set>
               </property>
               <property name="selectionBehavior">
                <enum>QAbstractItemView::SelectRows</enum>
               </property>
               <property name="columnCount"><number>5</number></property>
               <attribute name="horizontalHeaderStretchLastSection"><bool>true</bool></attribute>
               <column><property name="text"><string>Fecha</string></property></column>
               <column><property name="text"><string>Hora</string></property></column>
               <column><property name="text"><string>Tipo</string></property></column>
               <column><property name="text"><string>Tamaño</string></property></column>
               <column><property name="text"><string>Realizada por</string></property></column>
              </widget>
             </item>
            </layout>
           </widget>
          </item>

          <item>
           <layout class="QHBoxLayout">
            <item>
             <spacer>
              <property name="orientation"><enum>Qt::Horizontal</enum></property>
              <property name="sizeHint" stdset="0">
               <size><width>0</width><height>0</height></size>
              </property>
             </spacer>
            </item>
            <item>
             <widget class="QPushButton" name="btn_crear_backup">
              <property name="text"><string>Iniciar copia de seguridad</string></property>
             </widget>
            </item>
           </layout>
          </item>
         </layout>
        </widget>

       </widget>
      </item>
     </layout>
    </item>
   </layout>
  </widget>
 </widget>
