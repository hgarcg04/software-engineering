  <property name="styleSheet">
   <string notr="true">
    /* Fondo exterior: Azul suave degradado */
    QMainWindow { 
        background-color: #a2bdf2; 
    }
    
    /* Tarjeta Blanca Principal */
    #mainCard { 
        background-color: #ffffff; 
        border-radius: 40px; 
    }

    /* Panel Izquierdo: Verde Pastel */
    #leftPanel {
        background-color: #d8f3ed;
        border-top-left-radius: 40px;
        border-bottom-left-radius: 40px;
    }

    /* Títulos y Etiquetas */
    #lbl_hello { 
        color: #2d3436; 
        font-family: 'Segoe UI Black', sans-serif; 
        font-size: 55px; 
    }
    #lbl_subtitle { 
        color: #636e72; 
        font-family: 'Segoe UI', sans-serif; 
        font-size: 18px; 
    }
    #lbl_logo_text { 
        color: #2d3436; 
        font-family: 'Segoe UI Semibold'; 
        font-size: 24px; 
    }
    #lbl_kura { color: #00b894; font-weight: bold; } /* Verde del logo */

    /* Campos de Entrada */
    QLineEdit {
        border: 1px solid #dfe6e9;
        border-radius: 10px;
        padding: 12px;
        background-color: #ffffff;
        font-size: 14px;
        color: #2d3436;
    }
    QLineEdit:focus {
        border: 1px solid #6a9edb;
    }

    /* Botón Log In: Azul Redondeado */
    #btn_login {
        background-color: #6a9edb;
        color: white;
        border-radius: 22px;
        padding: 12px;
        font-family: 'Segoe UI Semibold';
        font-size: 16px;
    }
    #btn_login:hover { background-color: #5a8dc7; }

    /* Enlaces Inferiores */
    #lbl_forgot, #lbl_signup { 
        color: #00b894; 
        font-size: 13px;
        font-weight: bold;
    }
   </string>
