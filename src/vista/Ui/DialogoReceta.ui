<?xml version="1.0" encoding="UTF-8"?>
<ui version="4.0">
 <class>DialogoReceta</class>
 <widget class="QDialog" name="DialogoReceta">
  <property name="geometry">
   <rect>
    <x>0</x>
    <y>0</y>
    <width>900</width>
    <height>650</height>
   </rect>
  </property>
  <property name="windowTitle">
   <string>KURA - Recetar medicación</string>
  </property>
  <property name="styleSheet">
   <string notr="true">
    QDialog { background-color: #f0f4f8; }

    #lbl_titulo {
        font-family: 'Segoe UI Black';
        font-size: 20px;
        color: #2d3436;
    }
    #lbl_subtitulo {
        font-family: 'Segoe UI';
        font-size: 13px;
        color: #636e72;
    }

    #frame_pac {
        background-color: #d8f3ed;
        border: 1.5px solid #00b894;
        border-radius: 10px;
        padding: 4px 12px;
    }
    #lbl_pac_texto {
        font-family: 'Segoe UI';
        font-size: 13px;
        color: #636e72;
    }
    #lbl_pac_nombre {
        font-family: 'Segoe UI Semibold';
        font-size: 14px;
        color: #00a381;
    }

    #frame_alerta_ok {
        background-color: #d8f3ed;
        border: 1.5px solid #00b894;
        border-radius: 10px;
        padding: 4px 12px;
    }
    #frame_alerta_warn {
        background-color: #fff3cd;
        border: 1.5px solid #f39c12;
        border-radius: 10px;
        padding: 4px 12px;
    }
    #lbl_alerta {
        font-family: 'Segoe UI Semibold';
        font-size: 13px;
        color: #2d3436;
    }

    QTableWidget {
        background-color: #ffffff;
        border: 1px solid #dde3ea;
        border-radius: 10px;
        gridline-color: #f0f4f8;
        font-size: 13px;
    }
    QTableWidget::item { padding: 8px; }
    QTableWidget::item:selected { background-color: #00a381; color: white; }
    QHeaderView::section {
        background-color: #f8fafc;
        color: #636e72;
        font-family: 'Segoe UI Semibold';
        font-size: 12px;
        padding: 8px;
        border: none;
        border-bottom: 1px solid #dde3ea;
    }

    QLineEdit, QTextEdit, QComboBox, QDateEdit {
        background-color: #ffffff;
        border: 1px solid #dde3ea;
        border-radius: 8px;
        padding: 6px 10px;
        font-family: 'Segoe UI';
        font-size: 13px;
        color: #2d3436;
    }
    QLineEdit:focus, QTextEdit:focus, QComboBox:focus, QDateEdit:focus {
        border: 1px solid #00b894;
    }

    QLabel {
        font-family: 'Segoe UI';
        font-size: 13px;
        color: #2d3436;
    }

    #lbl_med_seleccionado {
        font-family: 'Segoe UI Semibold';
        font-size: 13px;
        color: #00a381;
        background-color: #f8fafc;
        border: 1px solid #dde3ea;
        border-radius: 8px;
        padding: 6px 10px;
    }

    #btn_prescribir {
        background-color: #00b894;
        color: white;
        border-radius: 8px;
        padding: 10px 24px;
        font-family: 'Segoe UI Semibold';
        font-size: 14px;
        border: none;
    }
    #btn_prescribir:hover { background-color: #00a381; }
    #btn_prescribir:disabled { background-color: #b2d8d0; color: #ffffff; }

    #btn_cancelar {
        background-color: #dfe6e9;
        color: #2d3436;
        border-radius: 8px;
        padding: 10px 24px;
        font-family: 'Segoe UI Semibold';
        font-size: 14px;
        border: none;
    }
    #btn_cancelar:hover { background-color: #b2bec3; }

    #search_bar {
        border: 1px solid #dde3ea;
        border-radius: 8px;
        padding: 8px 12px;
        background-color: #ffffff;
        font-size: 13px;
        color: #2d3436;
    }
    #search_bar:focus { border: 1px solid #00b894; }

    #lbl_col_titulo {
        font-family: 'Segoe UI Semibold';
        font-size: 15px;
        color: #2d3436;
    }
   </string>
  </property>
  <layout class="QVBoxLayout" name="mainLayout">
   <property name="spacing"><number>12</number></property>
   <property name="leftMargin"><number>24</number></property>
   <property name="topMargin"><number>24</number></property>
   <property name="rightMargin"><number>24</number></property>
   <property name="bottomMargin"><number>24</number></property>

   <!-- CABECERA -->
   <item>
    <widget class="QLabel" name="lbl_titulo">
     <property name="text"><string>Recetar medicación</string></property>
    </widget>
   </item>
   <item>
    <widget class="QFrame" name="frame_pac">
     <layout class="QHBoxLayout">
      <property name="leftMargin"><number>12</number></property>
      <property name="topMargin"><number>8</number></property>
      <property name="rightMargin"><number>12</number></property>
      <property name="bottomMargin"><number>8</number></property>
      <item>
       <widget class="QLabel" name="lbl_pac_texto">
        <property name="text"><string>Prescribiendo para:</string></property>
       </widget>
      </item>
      <item>
       <widget class="QLabel" name="lbl_pac_nombre">
        <property name="text"><string>— Sin paciente —</string></property>
       </widget>
      </item>
      <item>
       <spacer>
        <property name="orientation"><enum>Qt::Horizontal</enum></property>
        <property name="sizeHint" stdset="0"><size><width>0</width><height>0</height></size></property>
       </spacer>
      </item>
     </layout>
    </widget>
   </item>

   <!-- ALERTA ALERGIAS -->
   <item>
    <widget class="QFrame" name="frame_alerta_ok">
     <layout class="QHBoxLayout">
      <property name="leftMargin"><number>12</number></property>
      <property name="topMargin"><number>8</number></property>
      <property name="rightMargin"><number>12</number></property>
      <property name="bottomMargin"><number>8</number></property>
      <item>
       <widget class="QLabel" name="lbl_alerta">
        <property name="text"><string>✓ Sin alertas de alergias ni incompatibilidades</string></property>
       </widget>
      </item>
     </layout>
    </widget>
   </item>

   <!-- CUERPO: dos columnas -->
   <item>
    <layout class="QHBoxLayout" name="bodyLayout">
     <property name="spacing"><number>20</number></property>

     <!-- COLUMNA IZQUIERDA: catálogo de medicamentos -->
     <item>
      <layout class="QVBoxLayout" name="catalogoLayout">
       <item>
        <widget class="QLabel" name="lbl_col_titulo">
         <property name="text"><string>Catálogo de medicamentos</string></property>
        </widget>
       </item>
       <item>
        <widget class="QLineEdit" name="search_bar">
         <property name="placeholderText">
          <string>Buscar por nombre o categoría...</string>
         </property>
         <property name="clearButtonEnabled"><bool>true</bool></property>
        </widget>
       </item>
       <item>
        <widget class="QTableWidget" name="tabla_medicamentos">
         <property name="editTriggers"><set>QAbstractItemView::NoEditTriggers</set></property>
         <property name="selectionBehavior"><enum>QAbstractItemView::SelectRows</enum></property>
         <property name="selectionMode"><enum>QAbstractItemView::SingleSelection</enum></property>
         <property name="columnCount"><number>2</number></property>
         <attribute name="horizontalHeaderStretchLastSection"><bool>true</bool></attribute>
         <column><property name="text"><string>Medicamento</string></property></column>
         <column><property name="text"><string>Categoría</string></property></column>
        </widget>
       </item>
      </layout>
     </item>

     <!-- COLUMNA DERECHA: formulario de pauta -->
     <item>
      <layout class="QVBoxLayout" name="formLayout">
       <item>
        <widget class="QLabel" name="lbl_col_titulo">
         <property name="text"><string>Pauta del tratamiento</string></property>
        </widget>
       </item>
       <item>
        <layout class="QFormLayout" name="formReceta">

         <item row="0" column="0">
          <widget class="QLabel"><property name="text"><string>Medicamento:</string></property></widget>
         </item>
         <item row="0" column="1">
          <widget class="QLabel" name="lbl_med_seleccionado">
           <property name="text"><string>— Selecciona uno de la tabla —</string></property>
          </widget>
         </item>

         <item row="1" column="0">
          <widget class="QLabel"><property name="text"><string>Dosis:</string></property></widget>
         </item>
         <item row="1" column="1">
          <widget class="QLineEdit" name="edit_dosis">
           <property name="placeholderText"><string>Ej: 500mg, 1 comprimido...</string></property>
          </widget>
         </item>

         <item row="2" column="0">
          <widget class="QLabel"><property name="text"><string>Frecuencia:</string></property></widget>
         </item>
         <item row="2" column="1">
          <widget class="QLineEdit" name="edit_frecuencia">
           <property name="placeholderText"><string>Ej: Cada 8 horas, Una vez al día...</string></property>
          </widget>
         </item>

         <item row="3" column="0">
          <widget class="QLabel"><property name="text"><string>Vía de administración:</string></property></widget>
         </item>
         <item row="3" column="1">
          <widget class="QComboBox" name="combo_via">
           <item><property name="text"><string>Oral</string></property></item>
           <item><property name="text"><string>Intravenosa</string></property></item>
           <item><property name="text"><string>Intramuscular</string></property></item>
           <item><property name="text"><string>Subcutánea</string></property></item>
           <item><property name="text"><string>Tópica</string></property></item>
           <item><property name="text"><string>Inhalatoria</string></property></item>
          </widget>
         </item>

         <item row="4" column="0">
          <widget class="QLabel"><property name="text"><string>Fecha de inicio:</string></property></widget>
         </item>
         <item row="4" column="1">
          <widget class="QDateEdit" name="date_inicio">
           <property name="calendarPopup"><bool>true</bool></property>
           <property name="displayFormat"><string>dd/MM/yyyy</string></property>
          </widget>
         </item>

         <item row="5" column="0">
          <widget class="QLabel"><property name="text"><string>Fecha de fin:</string></property></widget>
         </item>
         <item row="5" column="1">
          <widget class="QDateEdit" name="date_fin">
           <property name="calendarPopup"><bool>true</bool></property>
           <property name="displayFormat"><string>dd/MM/yyyy</string></property>
          </widget>
         </item>

         <item row="6" column="0">
          <widget class="QLabel"><property name="text"><string>Notas para enfermería:</string></property></widget>
         </item>
         <item row="6" column="1">
          <widget class="QTextEdit" name="edit_notas">
           <property name="placeholderText">
            <string>Indicaciones especiales para el personal de enfermería...</string>
           </property>
           <property name="maximumHeight">
            <number>80</number>
           </property>
          </widget>
         </item>

        </layout>
       </item>

       <item>
        <spacer>
         <property name="orientation"><enum>Qt::Vertical</enum></property>
         <property name="sizeHint" stdset="0"><size><width>0</width><height>0</height></size></property>
        </spacer>
       </item>

       <!-- BOTONES -->
       <item>
        <layout class="QHBoxLayout">
         <item>
          <spacer>
           <property name="orientation"><enum>Qt::Horizontal</enum></property>
           <property name="sizeHint" stdset="0"><size><width>0</width><height>0</height></size></property>
          </spacer>
         </item>
         <item>
          <widget class="QPushButton" name="btn_cancelar">
           <property name="text"><string>Cancelar</string></property>
          </widget>
         </item>
         <item>
          <widget class="QPushButton" name="btn_prescribir">
           <property name="enabled"><bool>false</bool></property>
           <property name="text"><string>Prescribir tratamiento</string></property>
          </widget>
         </item>
        </layout>
       </item>

      </layout>
     </item>

    </layout>
   </item>

  </layout>
 </widget>
 <resources/>
 <connections/>
</ui>
