        <!-- PAGE 0: INICIO -->
        <widget class="QWidget" name="page_inicio">
         <layout class="QVBoxLayout" name="inicioLayout">
          <property name="leftMargin"><number>30</number></property>
          <property name="topMargin"><number>30</number></property>
          <property name="rightMargin"><number>30</number></property>
          <property name="bottomMargin"><number>30</number></property>
          <item><widget class="QLabel" name="lbl_section_title"><property name="text"><string>Agenda de hoy</string></property></widget></item>
          <item><widget class="QLabel" name="lbl_section_sub"><property name="text"><string>Selecciona una cita y pulsa "Iniciar consulta" para comenzar</string></property></widget></item>
