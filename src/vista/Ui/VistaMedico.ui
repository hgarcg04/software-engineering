          <property name="topMargin"><number>30</number></property>
          <property name="rightMargin"><number>30</number></property>
          <property name="bottomMargin"><number>30</number></property>
          <item>
           <layout class="QVBoxLayout" name="hcdListLayout">
            <item><widget class="QLabel" name="lbl_section_title"><property name="text"><string>Historial Clínico Digital</string></property></widget></item>
            <item><widget class="QLabel" name="lbl_col_titulo"><property name="text"><string>Buscar paciente</string></property></widget></item>
            <item>
             <widget class="QLineEdit" name="search_bar">
              <property name="placeholderText"><string>Buscar por nombre, apellido(s) o NIF...</string></property>
              <property name="clearButtonEnabled"><bool>true</bool></property>
             </widget>
            </item>
            <item>
             <widget class="QTableWidget" name="tabla_busqueda_hcd">
              <property name="editTriggers"><set>QAbstractItemView::NoEditTriggers</set></property>
              <property name="selectionBehavior"><enum>QAbstractItemView::SelectRows</enum></property>
