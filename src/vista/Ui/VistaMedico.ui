            <item><spacer><property name="orientation"><enum>Qt::Horizontal</enum></property><property name="sizeHint" stdset="0"><size><width>0</width><height>0</height></size></property></spacer></item>
            <item><widget class="QPushButton" name="btn_iniciar_consulta"><property name="enabled"><bool>false</bool></property><property name="text"><string>Iniciar consulta</string></property></widget></item>
            <item><widget class="QPushButton" name="btn_ver_hcd_inicio"><property name="enabled"><bool>false</bool></property><property name="text"><string>Ver HCD del paciente</string></property></widget></item>
            <item><spacer><property name="orientation"><enum>Qt::Horizontal</enum></property><property name="sizeHint" stdset="0"><size><width>0</width><height>0</height></size></property></spacer></item>
