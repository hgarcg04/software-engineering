          <property name="rightMargin"><number>30</number></property>
          <property name="bottomMargin"><number>30</number></property>
          <item><widget class="QLabel" name="lbl_section_title"><property name="text"><string>Mi agenda</string></property></widget></item>
          <item><widget class="QLabel" name="lbl_section_sub"><property name="text"><string>Consulta tus citas en cualquier rango de fechas</string></property></widget></item>
          <item>
