             </widget>
            </item>
            <item>
             <widget class="QFrame" name="frame_pac_hcd">
              <layout class="QHBoxLayout">
               <property name="leftMargin"><number>12</number></property>
               <property name="topMargin"><number>8</number></property>
               <property name="rightMargin"><number>12</number></property>
               <property name="bottomMargin"><number>8</number></property>
               <item><widget class="QLabel" name="lbl_paciente_sel_texto"><property name="text"><string>Episodios de:</string></property></widget></item>
               <item><widget class="QLabel" name="lbl_paciente_sel_nombre"><property name="text"><string>— Sin paciente seleccionado —</string></property></widget></item>
