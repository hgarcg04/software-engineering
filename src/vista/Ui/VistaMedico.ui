           </widget>
          </item>
          <item>
           <layout class="QFormLayout" name="formConsulta">
            <item row="0" column="0"><widget class="QLabel"><property name="text"><string>Síntomas:</string></property></widget></item>
            <item row="0" column="1"><widget class="QTextEdit" name="edit_sintomas"><property name="placeholderText"><string>Describe los síntomas del paciente...</string></property><property name="maximumHeight"><number>90</number></property></widget></item>
            <item row="1" column="0"><widget class="QLabel"><property name="text"><string>Diagnóstico:</string></property></widget></item>
            <item row="1" column="1"><widget class="QTextEdit" name="edit_diagnostico"><property name="placeholderText"><string>Introduce el diagnóstico clínico...</string></property><property name="maximumHeight"><number>90</number></property></widget></item>
            <item row="2" column="0"><widget class="QLabel"><property name="text"><string>Tipo de episodio:</string></property></widget></item>
            <item row="2" column="1">
             <widget class="QComboBox" name="combo_tipo_episodio">
              <item><property name="text"><string>Consulta</string></property></item>
              <item><property name="text"><string>Urgencia</string></property></item>
              <item><property name="text"><string>Revisión</string></property></item>
             </widget>
            </item>
           </layout>
          </item>
          <item>
