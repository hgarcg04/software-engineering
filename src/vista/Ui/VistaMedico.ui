        <widget class="QWidget" name="page_consulta">
         <layout class="QVBoxLayout" name="consultaLayout">
          <property name="leftMargin"><number>30</number></property>
          <property name="topMargin"><number>30</number></property>
          <property name="rightMargin"><number>30</number></property>
          <property name="bottomMargin"><number>30</number></property>
          <item>
           <layout class="QHBoxLayout">
            <item><widget class="QLabel" name="lbl_section_title"><property name="text"><string>Consulta médica</string></property></widget></item>
            <item><spacer><property name="orientation"><enum>Qt::Horizontal</enum></property><property name="sizeHint" stdset="0"><size><width>0</width><height>0</height></size></property></spacer></item>
            <item><widget class="QPushButton" name="btn_volver_consulta"><property name="text"><string>← Volver a inicio</string></property></widget></item>
           </layout>
          </item>
          <item>
           <widget class="QFrame" name="frame_cita_activa">
            <layout class="QHBoxLayout">
             <property name="leftMargin"><number>12</number></property>
             <property name="topMargin"><number>8</number></property>
             <property name="rightMargin"><number>12</number></property>
             <property name="bottomMargin"><number>8</number></property>
