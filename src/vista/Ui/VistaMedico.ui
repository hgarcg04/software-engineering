          <!-- Columna derecha: formulario de receta -->
          <item>
           <layout class="QVBoxLayout" name="recetaFormLayout">
            <item>
             <widget class="QLabel" name="lbl_section_title">
              <property name="text"><string>Pauta del tratamiento</string></property>
             </widget>
            </item>
            <item>
             <widget class="QFrame" name="frame_alerta">
              <layout class="QHBoxLayout">
               <property name="leftMargin"><number>12</number></property>
               <property name="topMargin"><number>8</number></property>
               <property name="rightMargin"><number>12</number></property>
               <property name="bottomMargin"><number>8</number></property>
               <item>
                <widget class="QLabel" name="lbl_alerta">
                 <property name="text"><string>⚠ Sin alertas de alergias o incompatibilidades</string></property>
                </widget>
               </item>
              </layout>
             </widget>
            </item>
            <item>
             <layout class="QFormLayout" name="formReceta">
              <item row="0" column="0">
               <widget class="QLabel">
                <property name="text"><string>Medicamento:</string></property>
               </widget>
              </item>
              <item row="0" column="1">
               <widget class="QLabel" name="lbl_med_seleccionado">
                <property name="text"><string>— Ninguno seleccionado —</string></property>
               </widget>
              </item>
              <item row="1" column="0">
               <widget class="QLabel">
                <property name="text"><string>Dosis:</string></property>
               </widget>
              </item>
              <item row="1" column="1">
               <widget class="QLineEdit" name="edit_dosis">
                <property name="placeholderText">
                 <string>Ej: 500mg, 1 comprimido...</string>
                </property>
               </widget>
              </item>
              <item row="2" column="0">
               <widget class="QLabel">
                <property name="text"><string>Frecuencia:</string></property>
               </widget>
              </item>
              <item row="2" column="1">
               <widget class="QLineEdit" name="edit_frecuencia">
                <property name="placeholderText">
                 <string>Ej: Cada 8 horas, Una vez al día...</string>
                </property>
               </widget>
              </item>
              <item row="3" column="0">
               <widget class="QLabel">
                <property name="text"><string>Vía de administración:</string></property>
               </widget>
              </item>
              <item row="3" column="1">
               <widget class="QComboBox" name="combo_via">
                <item><property name="text"><string>Oral</string></property></item>
                <item><property name="text"><string>Intravenosa</string></property></item>
                <item><property name="text"><string>Intramuscular</string></property></item>
                <item><property name="text"><string>Subcutánea</string></property></item>
                <item><property name="text"><string>Tópica</string></property></item>
                <item><property name="text"><string>Inhalatoria</string></property></item>
               </widget>
              </item>
              <item row="4" column="0">
               <widget class="QLabel">
                <property name="text"><string>Fecha de inicio:</string></property>
               </widget>
              </item>
              <item row="4" column="1">
               <widget class="QDateEdit" name="date_inicio_receta">
                <property name="calendarPopup"><bool>true</bool></property>
                <property name="displayFormat"><string>dd/MM/yyyy</string></property>
               </widget>
              </item>
              <item row="5" column="0">
               <widget class="QLabel">
                <property name="text"><string>Fecha de fin:</string></property>
               </widget>
              </item>
              <item row="5" column="1">
               <widget class="QDateEdit" name="date_fin_receta">
                <property name="calendarPopup"><bool>true</bool></property>
                <property name="displayFormat"><string>dd/MM/yyyy</string></property>
               </widget>
              </item>
              <item row="6" column="0">
               <widget class="QLabel">
                <property name="text"><string>Notas para enfermería:</string></property>
               </widget>
              </item>
              <item row="6" column="1">
               <widget class="QTextEdit" name="edit_notas_receta">
                <property name="placeholderText">
                 <string>Indicaciones especiales para el personal de enfermería...</string>
                </property>
               </widget>
              </item>
             </layout>
            </item>
            <item>
             <layout class="QHBoxLayout">
              <item>
               <spacer>
                <property name="orientation"><enum>Qt::Horizontal</enum></property>
                <property name="sizeHint" stdset="0"><size><width>0</width><height>0</height></size></property>
