               </item>
              </layout>
             </widget>
            </item>
            <item>
             <widget class="QLabel" name="lbl_instrucciones">
              <property name="text"><string>Selecciona un medicamento del catálogo y rellena la pauta.</string></property>
             </widget>
            </item>
            <item>
             <widget class="QLineEdit" name="search_bar_medicamento">
              <property name="placeholderText">
               <string>Buscar medicamento por nombre o categoría...</string>
              </property>
              <property name="clearButtonEnabled"><bool>true</bool></property>
             </widget>
            </item>
            <item>
             <widget class="QTableWidget" name="tabla_medicamentos">
