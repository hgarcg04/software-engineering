        <!-- PAGE 2: INICIAR CONSULTA -->
        <widget class="QWidget" name="page_consulta">
         <layout class="QHBoxLayout" name="consultaOuterLayout">
          <property name="spacing"><number>20</number></property>
          <property name="leftMargin"><number>30</number></property>
          <property name="topMargin"><number>30</number></property>
          <property name="rightMargin"><number>30</number></property>
          <property name="bottomMargin"><number>30</number></property>
          <!-- Columna izquierda: formulario -->
          <item>
           <layout class="QVBoxLayout" name="consultaFormLayout">
            <item>
             <widget class="QLabel" name="lbl_section_title">
              <property name="text"><string>Iniciar consulta médica</string></property>
             </widget>
            </item>
            <item>
             <widget class="QFrame" name="frame_pac_consulta">
              <layout class="QHBoxLayout">
               <property name="leftMargin"><number>12</number></property>
               <property name="topMargin"><number>8</number></property>
               <property name="rightMargin"><number>12</number></property>
               <property name="bottomMargin"><number>8</number></property>
               <item>
                <widget class="QLabel" name="lbl_paciente_sel_texto">
                 <property name="text"><string>Consulta para:</string></property>
                </widget>
               </item>
               <item>
                <widget class="QLabel" name="lbl_paciente_sel_nombre_2">
                 <property name="text"><string>— Sin paciente seleccionado —</string></property>
                </widget>
               </item>
               <item>
                <spacer>
                 <property name="orientation"><enum>Qt::Horizontal</enum></property>
                 <property name="sizeHint" stdset="0"><size><width>0</width><height>0</height></size></property>
                </spacer>
               </item>
              </layout>
             </widget>
            </item>
            <item>
             <layout class="QFormLayout" name="formConsulta">
              <item row="0" column="0">
               <widget class="QLabel">
                <property name="text"><string>Síntomas:</string></property>
               </widget>
              </item>
              <item row="0" column="1">
               <widget class="QTextEdit" name="edit_sintomas">
                <property name="placeholderText">
                 <string>Describe los síntomas del paciente...</string>
                </property>
               </widget>
              </item>
              <item row="1" column="0">
               <widget class="QLabel">
                <property name="text"><string>Diagnóstico:</string></property>
               </widget>
              </item>
              <item row="1" column="1">
               <widget class="QTextEdit" name="edit_diagnostico">
                <property name="placeholderText">
                 <string>Introduce el diagnóstico clínico...</string>
                </property>
               </widget>
              </item>
              <item row="2" column="0">
               <widget class="QLabel">
                <property name="text"><string>Tipo de episodio:</string></property>
               </widget>
              </item>
              <item row="2" column="1">
               <widget class="QComboBox" name="combo_tipo_episodio">
                <item><property name="text"><string>Consulta</string></property></item>
                <item><property name="text"><string>Urgencia</string></property></item>
                <item><property name="text"><string>Revisión</string></property></item>
               </widget>
              </item>
             </layout>
            </item>
            <item>
             <layout class="QHBoxLayout">
              <item>
               <widget class="QPushButton" name="btn_ingresar_paciente">
                <property name="enabled"><bool>false</bool></property>
                <property name="text"><string>Ingresar paciente</string></property>
               </widget>
              </item>
              <item>
               <spacer>
                <property name="orientation"><enum>Qt::Horizontal</enum></property>
                <property name="sizeHint" stdset="0"><size><width>0</width><height>0</height></size></property>
               </spacer>
              </item>
              <item>
               <widget class="QPushButton" name="btn_guardar_consulta">
                <property name="enabled"><bool>false</bool></property>
